# Local Streamlit configuration.
# Copy this file to .env on your laptop and edit the values.

# Paste the public ngrok URL printed by the Kaggle BLIP-2 notebook.
BLIP2_SERVER_URL=https://YOUR-KAGGLE-BLIP2.ngrok-free.app

# Pinecone index used by your CLIP retrieval pipeline.
PINECONE_API_KEY=YOUR_PINECONE_KEY
PINECONE_INDEX_NAME=vr-clothing-gallery
PINECONE_NAMESPACE=finetuned-alpha-0.7

# Local copy of the Kaggle dataset shown in your screenshot.
# IMAGE_ROOT should be the folder that contains img/, gallery.csv, query.csv, train.csv, etc.
GALLERY_CSV=/absolute/path/to/version_5/gallery.csv
CAPTIONS_CSV=/absolute/path/to/version_5/blip2_captions_gallery.csv
IMAGE_ROOT=/absolute/path/to/version_5

# Local copy of clip_best.pt from the Kaggle dataset.
CLIP_CHECKPOINT=/absolute/path/to/version_5/clip_best.pt

# Optional runtime settings.
# Leave empty to use center/manual crop without YOLO.
# Set to yolov8n.pt if you want Ultralytics to auto-download the pretrained YOLOv8n weights.
YOLO_MODEL_PATH=
CLIP_MODEL=ViT-L-14
CLIP_PRETRAINED=openai
CANDIDATE_K=50
BLIP2_TIMEOUT_SECONDS=180
